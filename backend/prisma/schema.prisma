datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
}

model User {
    id  Int @id @default(autoincrement())
    email   String  @unique
    name    String @default("")
    password    String
    url_profile_image  String @default("")
    created_at  DateTime @default(now())
    Upload_Logs Upload_Logs[]
}

model Upload_Logs {
    id      Int @id @default(autoincrement())
    user_id     Int
    file_path   String
    created_at      DateTime @default(now())
    user User @relation(fields: [user_id], references: [id])
}